// SES Match — data model
// Modeled after the AISES "自社保有人材 / 案件" domain (rebuilt from scratch).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  // Direct (non-pooled) connection for migrations. On Vercel+Neon this is
  // DATABASE_URL_UNPOOLED; locally it mirrors DATABASE_URL.
  directUrl = env("DATABASE_URL_UNPOOLED")
}

// ---------- Tenancy ----------

model Organization {
  id                String   @id @default(cuid())
  name              String
  slug              String   @unique
  aiProvider        String   @default("mock") // mock | anthropic | openai
  proposalSignature String? // 提案メールの署名
  // LLMシステムプロンプトの上書き（null=組み込みデフォルト）。編集はプロンプト管理画面から。
  matchPrompt       String? // マッチ判定
  classifyPrompt    String? // メール分類
  talentPrompt      String? // 人材抽出
  projectPrompt     String? // 案件抽出
  proposalPrompt    String? // 提案文生成
  createdAt         DateTime @default(now())

  users       User[]
  talents     Talent[]
  projects    Project[]
  proposals   Proposal[]
  sharedLinks SharedLink[]
}

enum Role {
  ADMIN
  MEMBER
}

model User {
  id     String @id @default(cuid())
  orgId  String
  name   String
  email  String @unique
  role   Role   @default(MEMBER)

  org              Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  assignedTalents  Talent[]     @relation("TalentAssignee")
  assignedProjects Project[]    @relation("ProjectAssignee")
  favorites        Favorite[]
  createdProposals Proposal[]   @relation("ProposalAuthor")
}

// ---------- Shared enums ----------

enum TalentType {
  INHOUSE // 自社保有人材
  PARTNER // 協力会社
}

enum DataSource {
  REGISTER // 直登録
  EMAIL    // メール取り込み
}

enum TalentStatus {
  NONE
  PROPOSING // 提案中
  ACTIVE    // 稼働中
  CLOSED    // クローズ
}

enum ProjectStatus {
  OPEN      // 募集中
  PROPOSING // 提案中
  DECIDED   // 決定
  CLOSED    // クローズ
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum EmploymentType {
  EMPLOYEE  // 社員
  FREELANCE // 個人事業主 / フリーランス
}

enum Nationality {
  JAPAN
  OTHER
}

enum LanguageLevel {
  NATIVE   // ネイティブ
  BUSINESS // ビジネス
  DAILY    // 日常会話
  NONE
}

// 8-step remote preference, matching the source UI
enum RemotePreference {
  FULL_REMOTE   // フルリモート
  MOSTLY_REMOTE // 基本リモート
  HYBRID        // ハイブリッド
  OFFICE_1      // 週1回出社可
  OFFICE_2      // 週2回出社可
  OFFICE_3      // 週3回出社可
  OFFICE_4      // 週4回出社可
  ONSITE        // 常駐可
}

// ---------- Talent (人材) ----------

model Talent {
  id           String       @id @default(cuid())
  orgId        String
  managementId String? // 管理ID
  talentType   TalentType   @default(INHOUSE)
  dataFrom     DataSource   @default(REGISTER)
  status       TalentStatus @default(NONE)

  assigneeId String?
  name       String
  age        Int?
  gender     Gender?
  affiliation String? // 所属（例: 弊社個人事業主）

  employmentType   EmploymentType?
  nationality      Nationality?
  japaneseLevel    LanguageLevel?
  englishLevel     LanguageLevel?

  // 稼働開始
  availabilityText String? // 例: "即日or6月〜"
  availabilityDate DateTime?

  // 月額報酬（万円）
  desiredRateMin Int?
  desiredRateMax Int?

  remotePreference RemotePreference?
  nearestStation   String?

  // multi-value attributes
  mainSkills     String[] @default([])
  skills         String[] @default([])
  qualifications String[] @default([])
  tags           String[] @default([])

  emailSubject String? // メール件名（メール取り込み時）
  emailBody    String? // メール本文（取り込み元）
  emailFrom    String? // Fromヘッダ（表示用 例: 名前 <a@b.com>）
  emailTo      String? // Toヘッダ（表示用）
  sourceEmail  String? // 送信元メールアドレス（同一企業判定用）
  note         String?
  summaryText  String? // スキルシートのサマリ文（提案用テンプレ形式）
  receivedDate DateTime @default(now()) // 配信日

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  org         Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  assignee    User?        @relation("TalentAssignee", fields: [assigneeId], references: [id])
  attachments Attachment[]
  matches     Match[]
  favorites   Favorite[]
  proposals   Proposal[]

  @@index([orgId, talentType, status])
}

model Attachment {
  id       String @id @default(cuid())
  talentId String
  filename String
  url      String

  talent Talent @relation(fields: [talentId], references: [id], onDelete: Cascade)
}

// ---------- Project (案件) ----------

model Project {
  id           String        @id @default(cuid())
  orgId        String
  managementId String?
  title        String
  clientName   String? // エンド / 商流元
  businessFlow String? // 商流
  emailSubject String? // メール件名
  emailBody    String? // メール本文（取り込み元）
  emailFrom    String? // Fromヘッダ（表示用）
  emailTo      String? // Toヘッダ（表示用）
  sourceEmail  String? // 送信元メールアドレス（同一企業判定用）
  status       ProjectStatus @default(OPEN)
  dataFrom     DataSource    @default(REGISTER)

  assigneeId String?
  description String?

  // 商流（提案可否の判定材料）
  channelText String? // 商流制限の原文/要約（例: "プロパー〜1社先まで" "エンド直のみ"）
  supportFee  Boolean @default(false) // 支援費で商流を飛ばせる旨の記載があるか

  requiredSkills String[] @default([])
  tags           String[] @default([])

  rateMin Int?
  rateMax Int?

  remotePreference RemotePreference?
  location         String?
  nearestStation   String?

  startText String?
  startDate DateTime?

  receivedDate DateTime @default(now())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  org       Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  assignee  User?        @relation("ProjectAssignee", fields: [assigneeId], references: [id])
  matches   Match[]
  favorites Favorite[]
  proposals Proposal[]

  @@index([orgId, status])
}

// ---------- Matching ----------

model Match {
  id          String   @id @default(cuid())
  talentId    String
  projectId   String
  score       Float    @default(0)
  reasons     String[] @default([])
  proposable  Boolean  @default(true) // 商流的に提案可能か（false=商流オーバー等で提案不可）
  channelNote String? // 商流判定の理由（提案不可の根拠など）
  createdAt   DateTime @default(now())

  talent  Talent  @relation(fields: [talentId], references: [id], onDelete: Cascade)
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([talentId, projectId])
}

// ---------- Favorites (お気に入り) ----------

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  talentId  String?
  projectId String?
  createdAt DateTime @default(now())

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  talent  Talent?  @relation(fields: [talentId], references: [id], onDelete: Cascade)
  project Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([userId, talentId])
  @@unique([userId, projectId])
}

// ---------- Proposals (提案) ----------

enum ProposalStatus {
  DRAFT     // 下書き
  SENT      // 送信済み
  ACCEPTED  // 受諾
  REJECTED  // 見送り
}

model Proposal {
  id          String         @id @default(cuid())
  orgId       String
  talentId    String
  projectId   String
  subject     String?
  body        String
  status      ProposalStatus @default(DRAFT)
  score       Float?
  createdById String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  org       Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  talent    Talent       @relation(fields: [talentId], references: [id], onDelete: Cascade)
  project   Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdBy User?        @relation("ProposalAuthor", fields: [createdById], references: [id])

  @@index([orgId, status])
}

// ---------- Shared links (公開リンク) ----------

enum SharedLinkType {
  TALENT
  PROJECT
  TALENT_LIST
}

model SharedLink {
  id        String         @id @default(cuid())
  orgId     String
  token     String         @unique
  type      SharedLinkType
  targetId  String? // talentId / projectId （TALENT_LIST の場合は null）
  label     String?
  expiresAt DateTime?
  createdAt DateTime       @default(now())

  org Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId])
}

// ---------- Email ingestion (メール自動取り込み) ----------

enum IngestKind {
  TALENT  // 人材として登録
  PROJECT // 案件として登録
  IGNORE  // 対象外
  ERROR   // 処理エラー
}

model OAuthToken {
  id           String   @id @default(cuid())
  provider     String   @unique // "google"
  account      String? // 連携したメールアドレス
  refreshToken String
  scope        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model IngestedEmail {
  id         String     @id @default(cuid())
  orgId      String
  messageId  String     @unique // Gmail/RFC Message-ID（重複防止）
  gmailId    String? // Gmail内部ID
  fromAddr   String?
  subject    String?
  receivedAt DateTime?
  kind       IngestKind @default(IGNORE)
  talentId   String? // 作成した人材
  projectId  String? // 作成した案件
  reason     String? // 分類理由 / エラー内容
  createdAt  DateTime   @default(now())

  @@index([orgId, createdAt])
}
