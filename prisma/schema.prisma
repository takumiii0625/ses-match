// SES Match — data model
// Modeled after the AISES "自社保有人材 / 案件" domain (rebuilt from scratch).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  // Direct (non-pooled) connection for migrations. On Vercel+Neon this is
  // DATABASE_URL_UNPOOLED; locally it mirrors DATABASE_URL.
  directUrl = env("DATABASE_URL_UNPOOLED")
}

// ---------- Tenancy ----------

model Organization {
  id                String   @id @default(cuid())
  name              String
  slug              String   @unique
  aiProvider        String   @default("mock") // mock | anthropic | openai
  proposalSignature String? // 提案メールの署名
  // 案件案内メールの自動送信。ON時、日次マッチ後に「商流OK・80点以上・その日の新規・未送信」を自動送信。
  autoEmailEnabled  Boolean  @default(false)
  autoEmailDailyCap Int      @default(20) // 1日の自動送信上限（安全装置。手動送信も含めて計上）
  // 提携先への一斉送信（ブラスト）の1日上限（安全装置。本日のBlastRecipient.SENT件数で判定）。
  blastDailyCap     Int      @default(1000)
  // 日次マッチを最後に実行した日（JST "YYYY-MM-DD"）。1日1回だけ実行する冪等ガードに使う。
  lastRematchDate   String?
  // LLMシステムプロンプトの上書き（null=組み込みデフォルト）。編集はプロンプト管理画面から。
  matchPrompt       String? // マッチ判定
  classifyPrompt    String? // メール分類
  talentPrompt      String? // 人材抽出
  projectPrompt     String? // 案件抽出
  proposalPrompt    String? // 提案文生成
  projectEmailPrompt      String? // 案件案内メールの本文整形
  skillSheetPrompt        String? // スキルシート→サマリ生成
  skillSheetImprovePrompt String? // サマリ文の改善
  createdAt         DateTime @default(now())

  users            User[]
  talents          Talent[]
  projects         Project[]
  proposals        Proposal[]
  sharedLinks      SharedLink[]
  partnerCompanies PartnerCompany[]
  partnerContacts  PartnerContact[]
  blastCampaigns   BlastCampaign[]
}

enum Role {
  ADMIN
  MEMBER
}

model User {
  id     String @id @default(cuid())
  orgId  String
  name   String
  email  String @unique
  role   Role   @default(MEMBER)

  org              Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  assignedTalents  Talent[]     @relation("TalentAssignee")
  assignedProjects Project[]    @relation("ProjectAssignee")
  favorites        Favorite[]
  createdProposals Proposal[]   @relation("ProposalAuthor")
}

// ---------- Shared enums ----------

enum TalentType {
  INHOUSE // 自社保有人材
  PARTNER // 協力会社
}

enum DataSource {
  REGISTER // 直登録
  EMAIL    // メール取り込み
}

enum TalentStatus {
  NONE
  PROPOSING // 提案中
  ACTIVE    // 稼働中
  CLOSED    // クローズ
}

enum ProjectStatus {
  OPEN      // 募集中
  PROPOSING // 提案中
  DECIDED   // 決定
  CLOSED    // クローズ
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum EmploymentType {
  EMPLOYEE  // 社員
  FREELANCE // 個人事業主 / フリーランス
}

enum Nationality {
  JAPAN
  OTHER
}

enum LanguageLevel {
  NATIVE   // ネイティブ
  BUSINESS // ビジネス
  DAILY    // 日常会話
  NONE
}

// 8-step remote preference, matching the source UI
enum RemotePreference {
  FULL_REMOTE   // フルリモート
  MOSTLY_REMOTE // 基本リモート
  HYBRID        // ハイブリッド
  OFFICE_1      // 週1回出社可
  OFFICE_2      // 週2回出社可
  OFFICE_3      // 週3回出社可
  OFFICE_4      // 週4回出社可
  ONSITE        // 常駐可
}

// ---------- Talent (人材) ----------

model Talent {
  id           String       @id @default(cuid())
  orgId        String
  managementId String? // 管理ID
  talentType   TalentType   @default(INHOUSE)
  dataFrom     DataSource   @default(REGISTER)
  status       TalentStatus @default(NONE)

  assigneeId String?
  name       String
  age        Int?
  gender     Gender?
  affiliation String? // 所属（例: 弊社個人事業主）
  contactName String? // 紹介元の営業担当者名（メール署名から抽出。案内メールの宛名に使用）

  employmentType   EmploymentType?
  nationality      Nationality?
  japaneseLevel    LanguageLevel?
  englishLevel     LanguageLevel?

  // 稼働開始
  availabilityText String? // 例: "即日or6月〜"
  availabilityDate DateTime?

  // 月額報酬（万円）
  desiredRateMin Int?
  desiredRateMax Int?

  remotePreference RemotePreference?
  nearestStation   String?

  // multi-value attributes
  mainSkills     String[] @default([])
  skills         String[] @default([])
  qualifications String[] @default([])
  tags           String[] @default([])

  emailSubject String? // メール件名（メール取り込み時）
  emailBody    String? // メール本文（取り込み元）
  emailFrom    String? // Fromヘッダ（表示用 例: 名前 <a@b.com>）
  emailTo      String? // Toヘッダ（表示用）
  sourceEmail  String? // 送信元メールアドレス（同一企業判定用）
  note         String?
  summaryText  String? // スキルシートのサマリ文（提案用テンプレ形式）
  distributionSubject String? // 一斉案内メールの配信件名（人材ごと。未設定なら既定件名）
  receivedDate DateTime @default(now()) // 配信日

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  org         Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  assignee    User?        @relation("TalentAssignee", fields: [assigneeId], references: [id])
  attachments Attachment[]
  matches     Match[]
  favorites   Favorite[]
  proposals   Proposal[]

  @@index([orgId, talentType, status])
}

model Attachment {
  id       String @id @default(cuid())
  talentId String
  filename String
  url      String

  talent Talent @relation(fields: [talentId], references: [id], onDelete: Cascade)
}

// ---------- Project (案件) ----------

model Project {
  id           String        @id @default(cuid())
  orgId        String
  managementId String?
  title        String
  clientName   String? // エンド / 商流元
  businessFlow String? // 商流
  emailSubject String? // メール件名
  emailBody    String? // メール本文（取り込み元）
  emailFrom    String? // Fromヘッダ（表示用）
  emailTo      String? // Toヘッダ（表示用）
  sourceEmail  String? // 送信元メールアドレス（同一企業判定用）
  status       ProjectStatus @default(OPEN)
  dataFrom     DataSource    @default(REGISTER)

  assigneeId String?
  description String?

  // 商流（提案可否の判定材料）
  channelText String? // 商流制限の原文/要約（例: "プロパー〜1社先まで" "エンド直のみ"）
  supportFee  Boolean @default(false) // 支援費で商流を飛ばせる旨の記載があるか

  formattedBody String? // 案内メール用に整形済みの案件本文（LLM整形結果のキャッシュ。再生成で更新）

  requiredSkills String[] @default([])
  tags           String[] @default([])

  rateMin Int?
  rateMax Int?

  remotePreference RemotePreference?
  location         String?
  nearestStation   String?

  startText String?
  startDate DateTime?

  receivedDate DateTime @default(now())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  org       Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  assignee  User?        @relation("ProjectAssignee", fields: [assigneeId], references: [id])
  matches   Match[]
  favorites Favorite[]
  proposals Proposal[]

  @@index([orgId, status])
}

// ---------- Matching ----------

model Match {
  id          String   @id @default(cuid())
  talentId    String
  projectId   String
  score       Float    @default(0)
  reasons     String[] @default([])
  proposable  Boolean  @default(true) // 商流的に提案可能か（false=商流オーバー等で提案不可）
  channelNote String? // 商流判定の理由（提案不可の根拠など）
  createdAt   DateTime @default(now())

  talent  Talent  @relation(fields: [talentId], references: [id], onDelete: Cascade)
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([talentId, projectId])
}

// ---------- Favorites (お気に入り) ----------

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  talentId  String?
  projectId String?
  createdAt DateTime @default(now())

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  talent  Talent?  @relation(fields: [talentId], references: [id], onDelete: Cascade)
  project Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([userId, talentId])
  @@unique([userId, projectId])
}

// ---------- Proposals (提案) ----------

enum ProposalStatus {
  DRAFT     // 下書き
  SENT      // 送信済み
  ACCEPTED  // 受諾
  REJECTED  // 見送り
}

model Proposal {
  id          String         @id @default(cuid())
  orgId       String
  talentId    String
  projectId   String
  subject     String?
  body        String
  status      ProposalStatus @default(DRAFT)
  score       Float?
  createdById String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  org       Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  talent    Talent       @relation(fields: [talentId], references: [id], onDelete: Cascade)
  project   Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdBy User?        @relation("ProposalAuthor", fields: [createdById], references: [id])

  @@index([orgId, status])
}

// ---------- Shared links (公開リンク) ----------

enum SharedLinkType {
  TALENT
  PROJECT
  TALENT_LIST
}

model SharedLink {
  id        String         @id @default(cuid())
  orgId     String
  token     String         @unique
  type      SharedLinkType
  targetId  String? // talentId / projectId （TALENT_LIST の場合は null）
  label     String?
  expiresAt DateTime?
  createdAt DateTime       @default(now())

  org Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId])
}

// ---------- Email ingestion (メール自動取り込み) ----------

enum IngestKind {
  TALENT    // 人材として登録
  PROJECT   // 案件として登録
  IGNORE    // 対象外
  ERROR     // 処理エラー
  DUPLICATE // 再送メール（同一ドメイン×同一本文。LLM未実行でスキップ）
}

model OAuthToken {
  id           String   @id @default(cuid())
  provider     String   @unique // "google"
  account      String? // 連携したメールアドレス
  refreshToken String
  scope        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model IngestedEmail {
  id         String     @id @default(cuid())
  orgId      String
  messageId  String     @unique // Gmail/RFC Message-ID（重複防止）
  gmailId    String? // Gmail内部ID
  fromAddr   String?
  subject    String?
  receivedAt DateTime?
  kind       IngestKind @default(IGNORE)
  talentId   String? // 作成した人材
  projectId  String? // 作成した案件
  reason     String? // 分類理由 / エラー内容
  bodyHash   String? // 送信元ドメイン＋正規化本文のハッシュ（再送メール検出用）
  createdAt  DateTime   @default(now())

  @@index([orgId, createdAt])
  @@index([orgId, bodyHash])
}

// LLM使用量の記録。logUsage から書き込み、/reports で日次・月次コストを可視化する。
model AiUsage {
  id           String   @id @default(cuid())
  tag          String // extract / match / project-email / proposal など
  model        String
  inputTokens  Int
  cacheRead    Int      @default(0)
  cacheWrite   Int      @default(0)
  outputTokens Int
  cost         Float // 概算USD
  createdAt    DateTime @default(now())

  @@index([createdAt])
}

// 送信したメール（案件→人材）の履歴。重複送信防止・送信履歴の表示に使う。
model SentEmail {
  id        String   @id @default(cuid())
  orgId     String
  talentId  String
  projectId String
  kind      String   @default("PROJECT_INFO") // PROJECT_INFO=案件案内(人材へ) / TALENT_PROPOSAL=要員提案(案件元へ)
  toAddr    String // 送信先メール
  subject   String
  status    String // SENT / FAILED
  error     String? // 失敗時の理由
  createdAt DateTime @default(now())

  @@index([orgId, createdAt])
  @@index([talentId, projectId])
}

// ---------- 提携先会社・連絡先（協力会社の一斉送信先） ----------

enum PartnerContactStatus {
  ACTIVE // 配信中（送信対象）
  BOUNCED // エラー停止（不達。送信対象外）
  UNSUBSCRIBED // 配信停止/解除/本人オプトアウト（送信対象外）
}

// 提携先（協力会社）。CSV取込・手動登録で作る。会社名でテナント内ユニーク。
model PartnerCompany {
  id        String   @id @default(cuid())
  orgId     String
  name      String // 会社名
  domain    String? // 連絡先メールから導出したドメイン（将来の人材/案件紐付け用）
  industry  String? // 業種
  phone     String?
  website   String?
  note      String?
  tags      String[] @default([])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  org      Organization     @relation(fields: [orgId], references: [id], onDelete: Cascade)
  contacts PartnerContact[]

  @@unique([orgId, name]) // CSV取込の冪等キー
  @@index([orgId])
}

// 提携先の連絡先（メールアドレス）。1社に複数可。配信状態を持つ。
model PartnerContact {
  id               String               @id @default(cuid())
  orgId            String // 非正規化（送信クエリ・スコープ簡素化）
  companyId        String
  email            String
  name             String? // 担当者名（CSVは「ご担当者」）
  role             String? // 役職
  status           PartnerContactStatus @default(ACTIVE)
  unsubscribeToken String               @unique @default(cuid()) // 配信停止リンク用
  bounceCount      Int                  @default(0)
  unsubscribedAt   DateTime?
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt

  org     Organization   @relation(fields: [orgId], references: [id], onDelete: Cascade)
  company PartnerCompany @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([orgId, email]) // CSV取込の冪等性（email一意）
  @@index([orgId, status]) // 配信中の一括抽出
  @@index([companyId])
}

// ---------- 一斉送信（ブラスト）キャンペーン ----------

enum BlastStatus {
  DRAFT
  QUEUED // 送信待ち（recipient採番済み、cron待ち）
  SENDING
  DONE
  FAILED
  CANCELED
}

enum BlastRecipientStatus {
  PENDING
  SENT
  FAILED
  SKIPPED
}

// 自社人材を提携先へ一斉紹介するキャンペーン。本文は確定済みを保存。
model BlastCampaign {
  id          String      @id @default(cuid())
  orgId       String
  subject     String
  body        String // 確定本文（人材ブロック込み。配信停止URLは送信時に各通へ差し込む）
  talentIds   String[]    @default([]) // 紹介した自社人材（履歴用）
  status      BlastStatus @default(DRAFT)
  totalCount  Int         @default(0)
  sentCount   Int         @default(0)
  failedCount Int         @default(0)
  createdById String?
  createdAt   DateTime    @default(now())
  startedAt   DateTime?
  finishedAt  DateTime?

  org        Organization     @relation(fields: [orgId], references: [id], onDelete: Cascade)
  recipients BlastRecipient[]

  @@index([orgId, createdAt])
  @@index([orgId, status])
}

// キャンペーンの送信対象1件（連絡先1つ）。PENDINGをcronが消化する。
model BlastRecipient {
  id         String               @id @default(cuid())
  campaignId String
  contactId  String
  toAddr     String // 採番時点のメール（連絡先削除後も履歴が残る）
  status     BlastRecipientStatus @default(PENDING)
  error      String?
  sentAt     DateTime?

  campaign BlastCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@unique([campaignId, contactId]) // 同一キャンペーンで二重送信不可
  @@index([campaignId, status]) // PENDINGだけ高速ドレイン
}
